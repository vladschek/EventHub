      },
      "dependsOn": [
        "monitoring",
        "serviceBus",
        "sql",
        "storage"
      ]
    }
  },
  "outputs": {
    "apiBaseUrl": {
      "type": "string",
      "value": "[reference('api').outputs.apiUrl.value]"
    },
    "functionAppBaseUrl": {
      "type": "string",
      "value": "[reference('functions').outputs.functionAppUrl.value]"
    },
    "sqlServerFqdn": {
      "type": "string",
      "value": "[reference('sql').outputs.serverFqdn.value]"
    },
    "sqlDatabaseName": {
      "type": "string",
      "value": "[reference('sql').outputs.databaseNameOut.value]"
    },
    "serviceBusNamespace": {
      "type": "string",
      "value": "[reference('serviceBus').outputs.namespaceNameOut.value]"
    },
    "applicationInsightsName": {
      "type": "string",
      "value": "[format('ai-{0}', variables('resourceToken'))]"
    },
    "postDeployHint": {
      "type": "string",
      "value": "Run EF migrations against sqlServerFqdn; configure SPA apiUrl to apiBaseUrl (HTTPS)."
    }
  }
}